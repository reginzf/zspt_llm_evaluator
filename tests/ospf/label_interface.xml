<View>
    <View style="background: #f5f5f5; padding: 15px; border-radius: 5px;">
      <Header value="切片文本" size="4"/>
      <Text name="text" value="$text" style="font-family: monospace;"/>
    </View>
  <View style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
    <View>
      <Header value="事实型" size="5"/>
      <Choices name="factual" toName="text" choice="multiple">
        <Choice value="ospf中有哪些类型的报文"/>
        <Choice value="ospf中的router Id是用来做什么的"/>
      </Choices>
    </View>
    <View>
      <Header value="上下文型" size="5"/>
      <Choices name="contextual" toName="text" choice="multiple">
        <Choice value="如果ospf进程100引入ospf101的区域内路由，在ospf100中应该生成什么样的lsa" background="#4CAF50"/>
        <Choice value="ospf支持哪些网络类型和路由类型" background="#FFC107"/>
      </Choices>
    </View>
    <View>
      <Header value="概念型" size="5"/>
      <Choices name="conceptual" toName="text" choice="multiple">
        <Choice value="什么ospf路由聚合" background="#4CAF50"/>
        <Choice value="ospf是如何进行主从关系协商、dd报文交换的" background="#FFC107"/>
      </Choices>
    </View>
    <View>
      <Header value="推理型" size="5"/>
      <Choices name="reasoning" toName="text" choice="multiple">
        <Choice value="如果ospf同时收到1类和2类外部路由，哪一类外部路由优先" background="#4CAF50"/>
        <Choice value="如果ospf邻居处于exstart，没有进入exchange可能是什么原因" background="#FFC107"/>
      </Choices>
    </View>
  </View>
</View>